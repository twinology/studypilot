# StudyPilot - Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul je eigen keys in.
# Keys kunnen ook via de Setup tab in de web interface worden ingesteld.

# AI Provider API key (Anthropic of OpenAI)
# Wordt overschreven als je via Setup tab een key instelt.
ANTHROPIC_API_KEY=

# ElevenLabs API key (optioneel - voor spraaksynthese)
# Zonder key wordt browser-spraak (Web Speech API) gebruikt als fallback.
ELEVENLABS_API_KEY=

# Telegram Bot Token (optioneel - voor de Telegram bot)
TELEGRAM_BOT_TOKEN=
